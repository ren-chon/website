{
  "name": "personal-website",
  "packageManager": "yarn@3.2.0",
  "private": true,
  "description": "",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "build:css && remix build",
    "build:css": "tailwindcss -i ./styles/tailwind.css -o ./app/tailwind.css --minify",
    "dev": "concurrently \"dev:css\" \"remix dev\"",
    "dev:css": "tailwindcss -i ./styles/tailwind.css -o ./app/tailwind.css --watch",
    "postinstall": "remix setup node"
  },
  "dependencies": {
    "@remix-run/node": "1.4.0-pre.2",
    "@remix-run/react": "1.4.0-pre.2",
    "@remix-run/serve": "1.4.0-pre.2",
    "concurrently": "^7.1.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@remix-run/dev": "1.4.0-pre.2",
    "@remix-run/eslint-config": "1.4.0-pre.2",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.13",
    "eslint": "^8.10.0",
    "npm-run-all": "^4.1.5",
    "prettier-plugin-tailwindcss": "^0.1.8",
    "tailwindcss": "^3.0.23",
    "typescript": "^4.6.2"
  }
}
